# {{PROJECT_NAME}} - Generated by install-and-maintain
# Works from any directory in the workspace
set dotenv-load := true

# Workspace root (works from any subfolder)
WORKSPACE_ROOT := `git rev-parse --show-toplevel`

default:
    @just --list

# ============================================
# SETUP (run from any folder in workspace)
# ============================================

# Deterministic setup (CI-friendly, fast)
setup:
    cd {{WORKSPACE_ROOT}} && claude --dangerously-skip-permissions --init

# Agentic setup with analysis and report
setup-report:
    cd {{WORKSPACE_ROOT}} && claude --dangerously-skip-permissions --init "/setup"

# Interactive guided setup with questions
setup-guide:
    cd {{WORKSPACE_ROOT}} && claude --dangerously-skip-permissions --init "/setup true"

# ============================================
# MAINTENANCE
# ============================================

# Deterministic maintenance (update deps)
maintain:
    cd {{WORKSPACE_ROOT}} && claude --dangerously-skip-permissions --maintenance

# Agentic maintenance with report
maintain-report:
    cd {{WORKSPACE_ROOT}} && claude --dangerously-skip-permissions --maintenance "/maintain"

# ============================================
# UTILITIES
# ============================================

# Reset build artifacts and logs
reset:
    rm -rf {{WORKSPACE_ROOT}}/.claude/hooks/*.log
    rm -rf {{WORKSPACE_ROOT}}/setup_docs/*.md
{{RESET_COMMANDS}}

# View setup logs
logs:
    @cat {{WORKSPACE_ROOT}}/.claude/hooks/setup.init.log 2>/dev/null || echo "No setup logs found"

# View maintenance logs
logs-maintain:
    @cat {{WORKSPACE_ROOT}}/.claude/hooks/setup.maintenance.log 2>/dev/null || echo "No maintenance logs found"

{{PROJECT_COMMANDS}}
