#!/usr/bin/env -S uv run --script
# /// script
# requires-python = ">=3.11"
# dependencies = []
# ///
"""
Claude Code Setup Hook: Repository Maintenance
Generated by install-and-maintain skill

Project: {{PROJECT_NAME}}
Type: {{WORKSPACE_TYPE}}

Triggered by: claude --maintenance
Purpose: Update dependencies and perform maintenance tasks
"""

import json
import os
import subprocess
import sys
from datetime import datetime
from pathlib import Path

# Configuration (generated from codebase analysis)
PROJECT_NAME = "{{PROJECT_NAME}}"
WORKSPACE_TYPE = "{{WORKSPACE_TYPE}}"

# Maintenance actions: list of (command, working_dir_relative_to_root)
MAINTENANCE_ACTIONS = [
{{MAINTENANCE_ACTIONS}}
]

# Log file
SCRIPT_DIR = Path(__file__).parent
LOG_FILE = SCRIPT_DIR / "setup.maintenance.log"


class Logger:
    """Simple logger that writes to both stderr and a log file."""

    def __init__(self, log_path: Path):
        self.log_path = log_path
        self.log_path.parent.mkdir(parents=True, exist_ok=True)
        with open(self.log_path, "a") as f:
            f.write(f"\n{'='*60}\n")
            f.write(f"=== Maintenance Hook Started: {datetime.now().isoformat()} ===\n")
            f.write(f"=== Project: {PROJECT_NAME} ===\n")
            f.write(f"{'='*60}\n")

    def log(self, message: str) -> None:
        print(message, file=sys.stderr)
        with open(self.log_path, "a") as f:
            f.write(message + "\n")


logger = Logger(LOG_FILE)


def get_workspace_root() -> str:
    """Get the workspace root directory."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True, text=True, check=True
        )
        return result.stdout.strip()
    except subprocess.CalledProcessError:
        return os.environ.get("CLAUDE_PROJECT_DIR", os.getcwd())


def read_hook_input() -> dict:
    """Read the JSON payload from stdin."""
    try:
        return json.load(sys.stdin)
    except (json.JSONDecodeError, EOFError):
        return {}


def output_result(context: str) -> dict:
    """Build and return structured JSON result."""
    return {
        "hookSpecificOutput": {
            "hookEventName": "Setup",
            "additionalContext": context
        }
    }


def run(cmd: list[str], cwd: str | None = None) -> tuple[bool, str]:
    """Run a command, log output. Returns (success, output)."""
    logger.log(f"  Running: {' '.join(cmd)}")
    if cwd:
        logger.log(f"  In: {cwd}")

    result = subprocess.run(cmd, cwd=cwd, capture_output=True, text=True)

    output_lines = []
    if result.stdout:
        for line in result.stdout.strip().split("\n")[:15]:
            logger.log(f"    {line}")
            output_lines.append(line)

    if result.returncode != 0:
        logger.log(f"  ERROR: Command failed with code {result.returncode}")
        if result.stderr:
            logger.log(f"  STDERR: {result.stderr[:500]}")
        return False, result.stderr

    return True, "\n".join(output_lines)


def main() -> None:
    hook_input = read_hook_input()

    logger.log("")
    logger.log("HOOK INPUT:")
    logger.log("-" * 60)
    logger.log(json.dumps(hook_input, indent=2) if hook_input else "{}")
    logger.log("")

    trigger = hook_input.get("trigger", "maintenance")
    session_id = hook_input.get("session_id", "unknown")

    workspace_root = get_workspace_root()

    logger.log(f"Project: {PROJECT_NAME}")
    logger.log(f"Type: {WORKSPACE_TYPE}")
    logger.log(f"Trigger: --{trigger}")
    logger.log(f"Session ID: {session_id}")
    logger.log(f"Workspace root: {workspace_root}")
    logger.log(f"Log file: {LOG_FILE}")
    logger.log("-" * 60)

    actions_completed = []
    actions_failed = []

    # Execute maintenance actions
    for cmd_str, relative_dir in MAINTENANCE_ACTIONS:
        cmd = cmd_str.split()
        cwd = os.path.join(workspace_root, relative_dir) if relative_dir else workspace_root

        logger.log(f"\n>>> {cmd_str}" + (f" (in {relative_dir})" if relative_dir else ""))

        success, output = run(cmd, cwd=cwd)

        if success:
            actions_completed.append(f"{cmd_str}" + (f" (in {relative_dir})" if relative_dir else ""))
        else:
            actions_failed.append(f"{cmd_str}: {output[:100]}")

    logger.log("\n" + "-" * 60)

    # Build summary
    if actions_failed:
        logger.log("Maintenance completed with errors!")
        status = "PARTIAL"
    else:
        logger.log("Maintenance completed successfully!")
        status = "SUCCESS"

    logger.log("-" * 60)

    summary = f"Maintenance {status} for {PROJECT_NAME}\n\n"

    if actions_completed:
        summary += "Completed:\n"
        for action in actions_completed:
            summary += f"  ✓ {action}\n"

    if actions_failed:
        summary += "\nFailed:\n"
        for action in actions_failed:
            summary += f"  ✗ {action}\n"

    summary += f"\nLog file: {LOG_FILE}"

    hook_output = output_result(summary)

    logger.log("")
    logger.log("HOOK OUTPUT:")
    logger.log("-" * 60)
    logger.log(json.dumps(hook_output, indent=2))

    with open(LOG_FILE, "a") as f:
        f.write(f"\n=== Maintenance Hook Completed: {datetime.now().isoformat()} ===\n")

    print(json.dumps(hook_output, indent=2))
    sys.exit(0 if not actions_failed else 2)


if __name__ == "__main__":
    main()
